PORT=5000
NODE_ENV=development

# false = MongoDB (MONGO_URI) | true = dosya: backend/data/pages.json
USE_FILE_DB=false
MONGO_URI=mongodb://127.0.0.1:27017/web_builder

# İsteğe bağlı: doluysa POST/DELETE/PATCH/PUT /api/* için zorunlu (GET açık kalır — önizleme).
# İstemci: X-Api-Key: ... veya Authorization: Bearer ...
API_KEY=

# Virgülle tam kökenler (örn. https://app.siteniz.com,http://localhost:5173). Boş = tüm kökenlere yansıtma (yalnızca dev için uygun).
CORS_ORIGINS=

# JSON gövdesi üst sınırı (Netlify zip base64 için genelde 8mb–32mb yeterli)
JSON_BODY_LIMIT=12mb

# Dakikada aynı IP için /api istek üst sınırı (/api/health sayılmaz)
API_RATE_MAX=240

# Ters proxy arkasında gerçek IP için atlama sayısı (0 = kapalı)
TRUST_PROXY_HOPS=0
